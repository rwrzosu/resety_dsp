/*
 * ezboardBF60x_initcode.ldf
 *
 * Custom LDF for ADSP-BF609 initcode dxe
 *
 * Copyright (c) 2011-2015 Analog Devices, Inc. All Rights Reserved.
 */

$OBJECTS = $COMMAND_LINE_OBJECTS;
$LIBRARIES = libcc.dlb, libevent.dlb;
$OBJS_LIBS = $OBJECTS, $LIBRARIES;

#if defined(CORE1) || defined(COREB)
  #error only setup for CORE0
#endif

MEMORY {
  MEM_L1_CODE         { START(0xFFA00000) END(0xFFA0FFFF) TYPE(RAM) WIDTH(8) }
  MEM_L1_DATA_A       { START(0xFF800000) END(0xFF807FFF) TYPE(RAM) WIDTH(8) }
}

PROCESSOR p0 {
  OUTPUT( $COMMAND_LINE_OUTPUT_FILE )
  KEEP(_initcode)
  RESOLVE(_initcode, 0xFFA00000)
  ENTRY(_initcode)
  
  SECTIONS {

    L1_code {
      INPUT_SECTION_ALIGN(4)
      INPUT_SECTIONS($OBJS_LIBS(program cplb_code))
    } > MEM_L1_CODE
    
    L1_data_a {
      INPUT_SECTION_ALIGN(4)
      INPUT_SECTIONS($OBJS_LIBS(data1))
    } > MEM_L1_DATA_A
    
  }
}